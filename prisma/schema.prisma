// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id Int @id @default(autoincrement())
  name String
  slug String @unique // Unique slug for clear URL
  descriptions Description[] @relation("ProjectDescriptions") //0 : c'est la short description
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  } 
  
  model Description {
    id Int @id @default(autoincrement())
    content String
    project Project @relation("ProjectDescriptions", fields: [projectId], references: [id], onDelete: Cascade)
    projectId Int
    images Image[]
    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())
  } 
  
  
  
  model Image {
    id Int @id @default(autoincrement())
    url String
    alt String? // Optional field for image description
    description Description @relation(fields: [descriptionId], references: [id], onDelete: Cascade)
    descriptionId Int 
    createdAt DateTime @default(now()) 
}