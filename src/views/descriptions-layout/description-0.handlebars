<article class="description-block description-0">
  <div class="description-top">
    <p class="description-text">{{content}}</p>
  </div>

  <div class="description-images-row">
    {{#each images}}
      <figure class="description-image-item">
        <img src="{{url}}" alt="{{alt}}" class="project-image" />
        <figcaption>{{alt}}</figcaption>
      </figure>
    {{/each}}
  </div>
</article>